# Google Apps Script Web App URL (Milestone 3 — cloud sync)
# 1. Deploy gas/Code.gs as a Web App (see gas/README.md).
# 2. Paste the /exec URL below (or save it in-app settings in m3-sync).
# Treat this URL like a private key — anyone with it can call your Sheet gateway.
EXPO_PUBLIC_GAS_WEB_APP_URL=https://script.google.com/macros/s/your-deployment-id/exec

# Optional: default Google Drive folder id for item photos (Script Property DRIVE_FOLDER_ID
# can also hold this). Folder id is the last segment of the Drive folder URL.
EXPO_PUBLIC_DEFAULT_DRIVE_FOLDER_ID=
